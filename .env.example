# SOC Triage Agent — environment configuration template
# Copy to `.env` (gitignored) and fill in real values to go live.
# With NOTHING set, everything runs in MOCK_MODE with zero creds.

# ============================================================================
# RUN MODE
# ============================================================================
# MOCK_MODE is ON by default. Set to 0/false to use live Databricks + real
# LLM endpoints (requires the creds below). When live creds are missing, the
# code transparently falls back to mock so notebooks always execute.
SOC_MOCK_MODE=1

# ============================================================================
# LLM SELECTION  (provider + models — fully configurable, no code edits)
# ============================================================================
# Provider: databricks (locked default) | openai | mock
LLM_PROVIDER=databricks

# Primary model and the SECOND model used in the dual-LLM evaluation.
# For Databricks Model Serving (Foundation Model APIs / your own endpoints):
LLM_MODEL=databricks-meta-llama-3-1-70b-instruct
LLM_MODEL_B=databricks-dbrx-instruct
# For OpenAI (when LLM_PROVIDER=openai), e.g.:
#   LLM_MODEL=gpt-4o-mini
#   LLM_MODEL_B=gpt-4o

# OpenAI-compatible base URL. For Databricks this is <host>/serving-endpoints.
# If left blank and DATABRICKS_HOST is set, it is derived automatically.
# LLM_BASE_URL=https://dbc-xxxxxxxx-xxxx.cloud.databricks.com/serving-endpoints

# API key for the LLM endpoint. For Databricks this is your PAT; if unset,
# DATABRICKS_TOKEN is used. For OpenAI, set LLM_API_KEY or OPENAI_API_KEY.
# LLM_API_KEY=
# OPENAI_API_KEY=

# Optional LLM tuning
# LLM_TEMPERATURE=0.0
# LLM_MAX_TOKENS=1024
# LLM_TIMEOUT=60

# ============================================================================
# DATABRICKS WORKSPACE / COMPUTE  (live gold-function execution)
# ============================================================================
# DATABRICKS_HOST=https://dbc-xxxxxxxx-xxxx.cloud.databricks.com
# DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXX
# One of the following selects how SQL runs against Unity Catalog:
#   - SQL warehouse via the Databricks SDK Statement Execution API:
# DATABRICKS_WAREHOUSE_ID=xxxxxxxxxxxxxxxx
#   - or a cluster via databricks-connect (Spark):
# DATABRICKS_CLUSTER_ID=xxxx-xxxxxx-xxxxxxxx

# Unity Catalog names (defaults match Sai's ETL pipeline)
# UC_CATALOG=soc_intelligence
# UC_GOLD_SCHEMA=gold
# UC_SILVER_SCHEMA=silver

# ============================================================================
# EXTERNAL THREAT-INTEL APIS  (all optional — mocked by default)
# ============================================================================
# VirusTotal & Shodan stay mocked unless a key is provided (gold host_ip is a
# hostname, not a routable IP, so live VT/Shodan lookups are not meaningful).
# VT_API_KEY=
# SHODAN_API_KEY=
# NVD is KEYLESS — real calls are made when online; a key only raises the rate
# limit. A static fixture is used as fallback when offline.
# NVD_API_KEY=

# ============================================================================
# MLFLOW
# ============================================================================
# MLFLOW_TRACKING_URI=file:./mlruns
# MLFLOW_EXPERIMENT=soc_triage_agent
